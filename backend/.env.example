APP_NAME=Smart Disk API
DEBUG=true
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=120
DATABASE_URL=postgresql+asyncpg://smartdisk:smartdisk@localhost:5432/smartdisk
CORS_ORIGINS=http://localhost:5173
FILES_ROOT=./data/files
MODELS_ROOT=../models
MAX_UPLOAD_MB=20
EMBEDDING_MODEL=../models/bge-m3
EMBEDDING_DIM=1024
TOP_K=8
RETRIEVAL_TOP_K=16
RERANKER_ENABLED=true
RERANKER_MODEL=../models/bge-reranker-base
LLM_PROVIDER=llama_cpp
LLM_MODEL_PATH=../models/Qwen3-4B-Q4_K_M.gguf
LLM_MODEL_NAME=Qwen3-4B-Q4_K_M
LLM_N_CTX=8192
LLM_MAX_TOKENS=1536
LLM_HISTORY_USER_CHARS=3000
LLM_HISTORY_ASSISTANT_CHARS=2500
LLM_TEMPERATURE=0.1
# false = всегда ответ от Qwen; при сбое — ошибка API, а не подмена фрагментами документов
LLM_FALLBACK_TO_STUB=false
